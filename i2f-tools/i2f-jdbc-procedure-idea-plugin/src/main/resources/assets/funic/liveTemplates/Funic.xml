<templateSet group="Funic">
    <template name="synchronized" value="synchronized($OBJ$) {&#10;    $END$&#10;};" toReformat="false" toShortenFQNames="true">
        <variable name="OBJ" expression="" defaultValue="&quot;lock&quot;" alwaysStopAt="true" />
        <context>
            <option name="Funic" value="true" />
        </context>
    </template>
    <template name="func" value="func $NAME$($PARAMETER$)$RETURN_TYPE$ {&#10;    $END$&#10;};" toReformat="false" toShortenFQNames="true">
        <variable name="NAME" expression="" defaultValue="&quot;test&quot;" alwaysStopAt="true" />
        <variable name="PARAMETER" expression="" defaultValue="&quot;&quot;" alwaysStopAt="true" />
        <variable name="RETURN_TYPE" expression="" defaultValue="&quot;&quot;" alwaysStopAt="true" />
        <context>
            <option name="Funic" value="true" />
        </context>
    </template>
    <template name="forrange" value="for($ITEM$ $BEGIN$ ... $FINISH$) {&#10;    $END$&#10;};" toReformat="false" toShortenFQNames="true">
        <variable name="ITEM" expression="" defaultValue="&quot;item&quot;" alwaysStopAt="true" />
        <variable name="BEGIN" expression="" defaultValue="&quot;0&quot;" alwaysStopAt="true" />
        <variable name="FINISH" expression="" defaultValue="&quot;10&quot;" alwaysStopAt="true" />
        <context>
            <option name="Funic" value="true" />
        </context>
    </template>
    <template name="for" value="for($BEGIN$;$CONDITION$;$INCR$) {&#10;    $END$&#10;};" toReformat="false" toShortenFQNames="true">
        <variable name="BEGIN" expression="" defaultValue="&quot;i=0&quot;" alwaysStopAt="true" />
        <variable name="CONDITION" expression="" defaultValue="&quot;i&lt;10&quot;" alwaysStopAt="true" />
        <variable name="INCR" expression="" defaultValue="&quot;i++&quot;" alwaysStopAt="true" />
        <context>
            <option name="Funic" value="true" />
        </context>
    </template>
    <template name="foreach" value="for($ITEM$ : $COLLECTION$) {&#10;    $END$&#10;};" toReformat="false" toShortenFQNames="true">
        <variable name="ITEM" expression="" defaultValue="&quot;item&quot;" alwaysStopAt="true" />
        <variable name="COLLECTION" expression="" defaultValue="&quot;list&quot;" alwaysStopAt="true" />
        <context>
            <option name="Funic" value="true" />
        </context>
    </template>
    <template name="dowhile" value="do {&#10;    $END$&#10;} while($CONDITION$);" toReformat="false" toShortenFQNames="true">
        <variable name="CONDITION" expression="" defaultValue="&quot;true&quot;" alwaysStopAt="true" />
        <context>
            <option name="Funic" value="true" />
        </context>
    </template>
    <template name="while" value="while($CONDITION$) {&#10;    $END$&#10;};" toReformat="false" toShortenFQNames="true">
        <variable name="CONDITION" expression="" defaultValue="&quot;true&quot;" alwaysStopAt="true" />
        <context>
            <option name="Funic" value="true" />
        </context>
    </template>
    <template name="ifelse" value="if($CONDITION$) {&#10;    $END$&#10;} else {&#10;    &#10;};" toReformat="false" toShortenFQNames="true">
        <variable name="CONDITION" expression="" defaultValue="&quot;true&quot;" alwaysStopAt="true" />
        <context>
            <option name="Funic" value="true" />
        </context>
    </template>
    <template name="if" value="if($CONDITION$) {&#10;    $END$&#10;};" toReformat="false" toShortenFQNames="true">
        <variable name="CONDITION" expression="" defaultValue="&quot;true&quot;" alwaysStopAt="true" />
        <context>
            <option name="Funic" value="true" />
        </context>
    </template>
    <template name="try" value="try{&#10;    $END$&#10;} catch ($EX_TYPE$ $EX_VAR$){&#10;&#10;}" description="" toReformat="false" toShortenFQNames="true">
        <variable name="EX_TYPE" expression="" defaultValue="&quot;Throwable&quot;" alwaysStopAt="true" />
        <variable name="EX_VAR" expression="" defaultValue="&quot;e&quot;" alwaysStopAt="true" />
        <context>
            <option name="Funic" value="true" />
        </context>
    </template>
</templateSet>