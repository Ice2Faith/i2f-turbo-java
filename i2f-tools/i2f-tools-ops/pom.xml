        <root.link.github>https://github.com/Ice2Faith/i2f-turbo-java</root.link.github>
        <root.link.gitee>https://gitee.com/Ice2Faith/i2f-turbo-java</root.link.gitee>
        <root.link.email>ugex_savelar@163.com</root.link.email>

