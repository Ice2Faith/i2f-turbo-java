{
  "groups": [
    {
      "name": "i2f.springboot.auth.permission",
      "type": "i2f.springboot.auth.permission.properties.CheckPermissionProperties",
      "sourceType": "i2f.springboot.auth.permission.properties.CheckPermissionProperties"
    }
  ],
  "properties": [
    {
      "name": "i2f.springboot.auth.permission.aspect.enable",
      "type": "java.lang.Boolean",
      "description": "enable permission aspect.",
      "sourceType": "i2f.springboot.auth.permission.aspect.CheckPermissionAspect",
      "defaultValue": true
    },
    {
      "name": "i2f.springboot.auth.permission",
      "type": "java.lang.Integer",
      "description": "permission aspect order, default is -999.",
      "sourceType": "i2f.springboot.auth.permission.properties.CheckPermissionProperties",
      "defaultValue": -999
    }
  ],
  "hints": [
    {
      "name": "server.servlet.jsp.class-name",
      "providers": [
        {
          "name": "class-reference",
          "parameters": {
            "target": "javax.servlet.http.HttpServlet"
          }
        }
      ]
    },
    {
      "name": "server.tomcat.accesslog.encoding",
      "providers": [
        {
          "name": "handle-as",
          "parameters": {
            "target": "java.nio.charset.Charset"
          }
        }
      ]
    }
  ]
}
